<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_profil"
    android:background="#1B3C53">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.16"
        app:layout_constraintWidth_percent="1">

        <ImageButton
            android:id="@+id/returnButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/roundcorner"
            android:src="@drawable/arrowback"
            android:contentDescription="stringback"/>

        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profil"
            android:textAlignment="center"
            android:textSize="40sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/alfa_font"/>

        <View
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="20dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/background"
        app:layout_constraintTop_toBottomOf="@id/topLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.80"
        app:layout_constraintWidth_percent="0.96"/>

            <TextView
                android:id="@+id/labelFirstName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Imię"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/topLayout"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueFirstName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelFirstName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelLastName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nazwisko"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valueFirstName"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueLastName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelLastName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telefon"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valueLastName"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valuePhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelPhone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valuePhone"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelWojewodztwo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Województwo"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valueEmail"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueWojewodztwo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelWojewodztwo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelPowiat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powiat"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valueWojewodztwo"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valuePowiat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelPowiat"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelGmina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gmina"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valuePowiat"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueGmina"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelGmina"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/labelMiejscowosc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Miejscowość"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/valueGmina"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/valueMiejscowosc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:fontFamily="@font/alfa_font"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/labelMiejscowosc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/edytujButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Edytuj dane"
        android:fontFamily="@font/alfa_font"
        android:textSize="20sp"
        app:cornerRadius="12dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FFFFFF"
        android:backgroundTint="#1B3C53"
        app:layout_constraintTop_toBottomOf="@id/valueMiejscowosc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>