<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_login"
    android:background="#1B3C53">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1B3C53"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.16"
        app:layout_constraintWidth_percent="1">

        <ImageButton
            android:id="@+id/returnButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/roundcorner"
            android:src="@drawable/arrowback"
            android:contentDescription="stringback"/>

        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zaloguj się"
            android:textAlignment="center"
            android:textSize="30sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/alfa_font"/>

        <ImageButton
            android:id="@+id/logButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/roundcorner"
            android:contentDescription="stringback"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/background"
        app:layout_constraintTop_toBottomOf="@id/topLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.80"
        app:layout_constraintWidth_percent="0.96"/>

    <EditText
        android:id="@+id/emailText"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Email:"
        android:fontFamily="@font/alfa_font"
        android:textColorHint="#BBBBBB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.374"
        app:layout_constraintWidth_percent="0.86"/>

    <EditText
        android:id="@+id/hasloText"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Hasło:"
        android:fontFamily="@font/alfa_font"
        android:textColorHint="#BBBBBB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        android:inputType="textPassword"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/emailText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/telefonText"
        app:layout_constraintWidth_percent="0.4"/>

    <EditText
        android:id="@+id/telefonText"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Nr telefonu:"
        android:fontFamily="@font/alfa_font"
        android:textColorHint="#BBBBBB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        android:inputType="phone"
        android:maxLength="11"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/emailText"
        app:layout_constraintStart_toEndOf="@id/hasloText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.4"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/wyczyscButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="#1B3C53"
        android:text="Wyczyść"
        android:fontFamily="@font/alfa_font"
        android:textSize="20sp"
        app:cornerRadius="12dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FFFFFF"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/hasloText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/loginButton"
        app:layout_constraintWidth_percent="0.4"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="#1B3C53"
        android:text="Zaloguj"
        android:fontFamily="@font/alfa_font"
        android:textSize="20sp"
        app:cornerRadius="12dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FFFFFF"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/hasloText"
        app:layout_constraintStart_toEndOf="@id/wyczyscButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.4"/>

</androidx.constraintlayout.widget.ConstraintLayout>
